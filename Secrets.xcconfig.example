MOONSHOT_API_KEY = sk-换成你的key
MOONSHOT_BASE_URL = https:/$()/api.moonshot.cn/v1
MOONSHOT_MODEL = moonshot-v1-8k-vision-preview

// 后端可切换开关：NO = 直连 Moonshot（dev 默认，冒烟测试路径），YES = 走 riddle-backend 代理。
USE_BACKEND = NO
// riddle-backend 部署后的域名（见 riddle-backend/docs/APP_INTEGRATION.md），末尾不带 /v1/reply。
BACKEND_URL = https:/$()/your-railway-domain.up.railway.app
// 与 riddle-backend 的 APP_SHARED_SECRET 环境变量保持一致。
APP_SHARED_SECRET = 换成后端的APP_SHARED_SECRET
